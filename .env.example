# CareerCopilot AI now supports several AI providers - you are NOT locked
# into Anthropic. Rename this file to .env and fill in ONE of the sections
# below. Without any key set, the app runs in MOCK MODE and every AI module
# returns realistic placeholder JSON so the whole app still works end-to-end.

# 1) Which provider to use. If left blank, the first provider below with a
#    key set will be auto-detected. Options: anthropic, openai, groq, openrouter, gemini
LLM_PROVIDER=

# 2) Anthropic (Claude) - https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# 3) OpenAI - https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# 4) Groq - https://console.groq.com/keys  (free tier, very fast)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# 5) OpenRouter - https://openrouter.ai/keys  (access to 100+ hosted models)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# 6) Google Gemini - https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
